# ─────────────────────────────────────────────
#  clashmate — environment variables
# ─────────────────────────────────────────────

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
OWNER=your_discord_user_id_here

# Clash of Clans API
# Get keys at: https://developer.clashofclans.com
# Add your MonkeyBytes static IP to the allowed IPs for each key.
# Multiple keys comma-separated for higher rate limits.
CLASH_OF_CLANS_API_KEYS=key1,key2,key3

# MongoDB Atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/clashmate?retryWrites=true&w=majority

# Bot settings
NODE_ENV=production
PORT=8070

# ── clashmate-service (service-backend on Server 2) ──────────────────────────
# URL of your clashmate-service instance. Leave blank while service is not yet
# running — CWL archive and advanced link lookups will gracefully return empty.
# INTERNAL_API_BASE_URL=http://<server2-ip-or-domain>:8080
# INTERNAL_API_KEY=generate_a_long_random_secret_here

# ── Player linking (cocdiscord.link) — optional ───────────────────────────────
# Only needed if you have access to the cocdiscord.link credentials.
# If left blank the bot uses its own local MongoDB linking system instead.
# DISCORD_LINK_USERNAME=
# DISCORD_LINK_PASSWORD=

# Optional: Guild log webhook (paste Discord webhook URL to log guild joins/leaves)
# GUILD_LOG_WEBHOOK_URL=

# Optional: Support server invite (shown in error messages)
# SUPPORT_SERVER_URL=https://discord.gg/yourserver

# ── Clan Poller (in-process data collection) ──────────────────────────────
# How often to poll each clan for changes, in milliseconds.
# Default: 120000 (2 minutes). The CoC API CDN caches responses for ~60-120s,
# so polling faster than this wastes API quota without gaining fresher data.
# If you have many tracked clans and limited API keys, increase this.
# POLL_INTERVAL_MS=120000

# Max clans fetched concurrently per poll tick. Lower this if you hit rate limits.
# POLL_CONCURRENCY=10
