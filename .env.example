# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_OWNER_IDS=

# Clash of Clans
CLASH_OF_CLANS_API_TOKEN=

# PostgreSQL / Neon
DATABASE_URL=
TEST_DATABASE_URL=

# Runtime
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Bot behavior
COMMAND_REGISTRATION=global
DEFAULT_TIMEZONE=UTC

# Worker polling intervals, in seconds
POLL_CLAN_SECONDS=300
POLL_CLAN_JITTER_SECONDS=60
POLL_PLAYER_SECONDS=900
POLL_PLAYER_JITTER_SECONDS=180
POLL_WAR_SECONDS=120
POLL_WAR_JITTER_SECONDS=30

# Support/suggestions command
SUPPORT_GUILD_ID=
SUGGESTIONS_FORUM_CHANNEL_ID=

# Optional diagnostics
SENTRY_DSN=
