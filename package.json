{
  "name": "clashmate",
  "version": "1.0.0",
  "description": "Clash of Clans Discord Bot — free for all, no Patreon gating",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "main": "./dist/index.js"
  },
  "private": true,
  "scripts": {
    "start": "npm run build && node --env-file=.env dist/index.js",
    "dev": "node --env-file=.env dist/index.js",
    "build": "tsc && tsc-alias",
    "prebuild": "rimraf dist",
    "deploy": "tsx --env-file=.env scripts/update_commands_script.ts",
    "test": "eslint .",
    "lint": "eslint --fix ."
  },
  "dependencies": {
    "axios": "^1.12.2",
    "canvas": "^3.2.3",
    "chalk": "^5.6.2",
    "clashofclans.js": "^4.0.1",
    "discord.js": "^14.25.0",
    "dotenv": "^16.0.0",
    "google-auth-library": "^9.15.0",
    "jsonwebtoken": "^9.0.0",
    "moment": "^2.29.1",
    "moment-duration-format": "^2.3.2",
    "moment-timezone": "^0.6.0",
    "mongodb": "^6.20.0",
    "ms": "^2.1.3",
    "nanoid": "^5.1.5",
    "pluralize": "^8.0.0",
    "radash": "^12.1.0",
    "readdirp": "^4.1.2",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/moment-duration-format": "^2.2.3",
    "@types/ms": "^0.7.31",
    "@types/node": "^24.9.1",
    "@types/pluralize": "^0.0.33",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.32.1",
    "dotenv": "^17.2.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "tsc-alias": "^1.8.11",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.9",
    "utf-8-validate": "^6.0.5"
  },
  "engines": {
    "node": ">=20.x"
  }
}
